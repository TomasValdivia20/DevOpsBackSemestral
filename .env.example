# Variables de entorno para dos servicios Spring Boot con RDS separados por servicio
# Copia este archivo a .env y completa los valores

# ── RDS Ventas ─────────────────────────────────────────────────────────────
DB_ENDPOINT_VENTAS=
DB_PORT_VENTAS=3306
DB_NAME_VENTAS=ventas_db
DB_USERNAME_VENTAS=
DB_PASSWORD_VENTAS=

# ── RDS Despachos ───────────────────────────────────────────────────────────
DB_ENDPOINT_DESPACHOS=
DB_PORT_DESPACHOS=3306
DB_NAME_DESPACHOS=despachos_db
DB_USERNAME_DESPACHOS=
DB_PASSWORD_DESPACHOS=

# ── Docker Hub ────────────────────────────────────────────────────────────
DOCKERHUB_USERNAME=tomasvaldivia20
DOCKERHUB_TOKEN=